{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "outDir": "./dist/",
    "rootDir": "./src/",
    "forceConsistentCasingInFileNames": true,
    "rewriteRelativeImportExtensions": true,
    "strict": true,
    "allowJs": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
