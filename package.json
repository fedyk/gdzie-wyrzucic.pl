    "@types/koa-static": "^4.0.4",
    "@types/node": "^25.9.1",
    "fuse.js": "^7.3.0",
    "koa": "^3.2.1",
    "koa-bodyparser": "^4.4.1",
    "koa-router": "^14.0.0",
    "koa-static": "^5.0.0",
